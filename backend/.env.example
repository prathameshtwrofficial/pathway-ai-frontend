# Environment Variables for AI Career Compass Backend
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000

# Firebase Configuration (already configured in config/firebase.js)
# Get these from Firebase Console > Project Settings
# FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/path/to/serviceAccountKey.json

# HuggingFace API Key (FREE TIER available)
# Get your free API key at: https://huggingface.co/settings/tokens
# This enables real AI chatbot responses using FLAN-T5 model
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Adzuna Job Search API (FREE TIER available)
# Get free API keys at: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# YouTube Data API (FREE TIER available)
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key

# NOTE: The app works WITHOUT these keys!
# - AI Chatbot will use intelligent keyword-based responses
# - ML service will use local heuristic-based analysis
# - Job search will use mock job data
# - Resources will show fallback content
# - Full functionality requires API keys